modules = ["python-3.12"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Python"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Quantum Research Cycle C37"

[[workflows.workflow]]
name = "Run Python"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "git fetch "
mode = "sequential"
author = 54178035

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git fetch origin git reset --hard origin/main"

[[workflows.workflow]]
name = "chmod +x generate_ssh_key.sh"
mode = "sequential"
author = 54178035

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "chmod +x generate_ssh_key.sh"

[[workflows.workflow]]
name = "bash generate_ssh_key.sh"
mode = "sequential"
author = 54178035

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash generate_ssh_key.sh"

[[workflows.workflow]]
name = "ssh -T git@github.com"
mode = "sequential"
author = 54178035

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "ssh -T git@github.com"

[[workflows.workflow]]
name = "Quantum Research Cycle C37"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd src/advanced_calculations/quantum_problem_hubbard_hts && bash run_research_cycle.sh"

[workflows.workflow.metadata]
outputType = "console"

[nix]
packages = ["arrow-cpp", "cairo", "clang", "ffmpeg-full", "file", "freetype", "gcc", "gdb", "ghostscript", "glib", "glibc", "glibcLocales", "gnumake", "gobject-introspection", "got", "gtk3", "kaggle", "lcms2", "libGL", "libGLU", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "nano", "openjpeg", "openssh", "pkg-config", "qhull", "rsync", "tcl", "tk", "tree", "vim-full", "xsimd", "zlib"]
channel = "stable-25_05"

[deployment]
deploymentTarget = "vm"
run = ["./bin/lum_vorax_complete", "--progressive-stress-all"]
build = ["make", "clean", "all"]

