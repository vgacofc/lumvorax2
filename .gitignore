# =========================
# PYTHON CACHE
# =========================
__pycache__/
*.pyc
*.pyo

# =========================
# ENV / SECRETS
# =========================
.env
.kaggle/
*.json

# =========================
# DEPENDENCIES / SYSTEM
# =========================
*.whl
*.tar
*.tar.gz

# =========================
# RESULTS ONLY (NOT CONFIG)
# =========================
results/
outputs/
checkpoints/
experiments/

# Ignorer uniquement les CSV de résultats
**/results/*.csv
**/outputs/*.csv

# Ignorer logs runtime uniquement
*.log

# =========================
# IMPORTANT: DO NOT IGNORE BENCHMARKS
# =========================
!benchmarks/
!benchmarks/**/*.csv

# =========================
# EXCEPTIONS (CRITICAL FOR YOUR PROJECT)
# =========================
!src/
!src/**

# NE PAS ignorer les archives workspace si utilisées comme source
# (sinon cassera ton pipeline)
!*.zipsrc/advanced_calculations/quantum_problem_hubbard_hts/logs/
src/advanced_calculations/quantum_problem_hubbard_hts/logs/
